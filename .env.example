# App Config
PROJECT_NAME="RAG Pipeline"
VERSION="1.0.0"
LOG_LEVEL=INFO

# Storage
WATCH_DIR=./uploads

# Database
DB_SERVER=localhost
DB_NAME=rag-pipeline
DB_DRIVER=ODBC Driver 17 for SQL Server

# OAuth2 / OIDC
OIDC_AUTHORITY=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
OIDC_REDIRECT_URI=http://localhost:5173/signin-oidc
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/signout-callback-oidc
OIDC_SCOPES="email profile roles offline_access openid identity.manage"

# Backend
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["*"]

# Frontend (Vite needs VITE_ prefix)
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=
VITE_OIDC_REDIRECT_URI=http://localhost:5173/signin-oidc
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/signout-callback-oidc
VITE_OIDC_SCOPES="email profile roles offline_access openid identity.manage"
VITE_API_BASE_URL=/api
